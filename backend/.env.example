# Copy to `.env` and fill in your (rotated) credentials. This file is gitignored.

# --- AWS S3 (source documents) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=my-rag-poc-docs-aws
S3_PREFIX=sample-docs/

# --- Pinecone (vector store + hosted embeddings) ---
PINECONE_API_KEY=
PINECONE_INDEX=rag-poc
# Hosted embedding model (1024-dim). See https://docs.pinecone.io/models
PINECONE_EMBED_MODEL=multilingual-e5-large

# --- Groq (generation) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# How many chunks to retrieve as context.
TOP_K=5

# --- Observability (optional): Langfuse tracing ---
# Free open-source LLM tracing. Sign up at https://cloud.langfuse.com (or self-host),
# create a project, and paste its keys. Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Enable EC2 start/stop/reboot actions (still require in-chat confirmation).
# Leave false for read-only. Requires ec2:StartInstances/StopInstances/RebootInstances.
ALLOW_MUTATIONS=false
