# Copy to `.env` and fill in your Groq API key.

PORT=3001

# --- Generation (Groq) ---
# Free API key from https://console.groq.com (API Keys). No credit card needed.
GROQ_API_KEY=
# Model id — see https://console.groq.com/docs/models for current names.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Retrieval (local, no key) ---
# Embedding model run locally via Transformers.js (downloaded once, then offline).
EMBED_MODEL=Xenova/all-MiniLM-L6-v2
# How many chunks to retrieve and pass to the model as context.
TOP_K=5
